rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function esDueno() {
      return request.auth != null
        && resource.data.usuarioId == request.auth.uid;
    }

    function crearPropio() {
      return request.auth != null
        && request.resource.data.usuarioId == request.auth.uid;
    }

    match /comentarios/{docId} {
      allow read: if request.auth != null
        && resource.data.usuarioId == request.auth.uid;
      allow create: if crearPropio();
      allow update, delete: if esDueno();
    }

    match /anotaciones/{anotacionId} {
      allow read: if request.auth != null
        && resource.data.usuarioId == request.auth.uid;
      allow create: if crearPropio();
      allow update, delete: if esDueno();
    }

    match /chatMessages/{messageId} {
      allow read, write: if true;
    }

    match /chatPresence/{sessionId} {
      allow read, write: if true;
    }

    function pedidoTextoValido() {
      return request.resource.data.texto is string
        && request.resource.data.texto.size() >= 3
        && request.resource.data.texto.size() <= 500;
    }

    function pedidoSinCambiarDatosClave() {
      return request.resource.data.usuarioId == resource.data.usuarioId
        && request.resource.data.texto == resource.data.texto
        && request.resource.data.compartir == resource.data.compartir
        && request.resource.data.nombre == resource.data.nombre;
    }

    match /pedidosOracion/{pedidoId} {
      allow read: if request.auth != null
        && (resource.data.compartir == true
          || resource.data.usuarioId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.usuarioId == request.auth.uid
        && pedidoTextoValido()
        && request.resource.data.compartir is bool
        && request.resource.data.nombre is string
        && request.resource.data.orandoPor == {};
      allow update: if request.auth != null
        && resource.data.usuarioId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.compartir == true
        && pedidoSinCambiarDatosClave();
      allow delete: if request.auth != null
        && resource.data.usuarioId == request.auth.uid;
    }
  }
}
